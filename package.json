{
  "name": "lorekit",
  "version": "0.3.0",
  "description": "Personal LLM Wiki toolkit — let AI build and maintain your knowledge base",
  "type": "module",
  "bin": {
    "lorekit": "bin/lorekit.js"
  },
  "files": [
    "dist/",
    "bin/lorekit.js",
    "skills/",
    "plugins/",
    "templates/",
    "VERSION"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test:smoke": "node --test tests/smoke/*.test.mjs",
    "verify": "tsc --noEmit && npm run build && npm run test:smoke",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build",
    "version": "node -p \"require('./package.json').version\" > VERSION && git add VERSION"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "llm",
    "wiki",
    "knowledge-base",
    "karpathy",
    "obsidian",
    "rag",
    "embedding"
  ],
  "author": "GYF0311",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GYF0311/lorekit.git"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0",
    "commander": "^12.0.0",
    "gray-matter": "^4.0.3",
    "tar": "^7.0.0",
    "turndown": "^7.2.0"
  },
  "optionalDependencies": {
    "sqlite-vec": "^0.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "@types/turndown": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.8.3",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.58.2"
  }
}
