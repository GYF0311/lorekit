#!/usr/bin/env bash
# lorekit wiki CLI вҖ” main dispatcher
set -euo pipefail

_resolve() {
  local t="$1" d
  if command -v greadlink >/dev/null 2>&1; then greadlink -f "$t"; return; fi
  if readlink -f / >/dev/null 2>&1; then readlink -f "$t"; return; fi
  while [ -L "$t" ]; do
    d=$(cd -P "$(dirname "$t")" && pwd); t=$(readlink "$t")
    [[ "$t" != /* ]] && t="$d/$t"
  done
  echo "$(cd -P "$(dirname "$t")" && pwd)/$(basename "$t")"
}

LOREKIT_ROOT="$(cd "$(dirname "$(_resolve "${BASH_SOURCE[0]}")")/.." && pwd)"
export LOREKIT_ROOT
LIB="$LOREKIT_ROOT/bin/lib"
# shellcheck source=lib/common.sh
source "$LIB/common.sh"

_banner() {
  local corpus pages indexed model
  corpus="$(lk_find_corpus 2>/dev/null || echo "вҖ”")"
  if [ "$corpus" != "вҖ”" ]; then
    pages=$(find "$corpus" -name "*.md" -not -path "*/.wiki/*" -not -name ".gitkeep" 2>/dev/null | wc -l | tr -d ' ')
    local db="$corpus/.wiki/vector.sqlite"
    if [ -f "$db" ]; then
      indexed=$(sqlite3 "$db" "SELECT COUNT(*) FROM documents;" 2>/dev/null || echo "0")
      model=$(sqlite3 "$db" "SELECT value FROM meta WHERE key='model';" 2>/dev/null || echo "вҖ”")
    else
      indexed="0"; model="вҖ”"
    fi
  else
    pages="вҖ”"; indexed="вҖ”"; model="вҖ”"
  fi
  local ver; ver="$(lk_version)"
  local C_C=$'\033[36m' C_B=$'\033[1m' C_D=$'\033[2m'
  printf '%sв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ%s\n' "$C_D" "$C_0"
  printf '%sв”Ӯ%s  %sрҹ“ҡ lorekit%s %-29s%sв”Ӯ%s\n' "$C_D" "$C_0" "$C_B" "$C_0" "v$ver" "$C_D" "$C_0"
  printf '%sв”Ӯ%s  Personal LLM Wiki Toolkit             %sв”Ӯ%s\n' "$C_D" "$C_0" "$C_D" "$C_0"
  printf '%sв”Ӯ%s                                         %sв”Ӯ%s\n' "$C_D" "$C_0" "$C_D" "$C_0"
  local short_corpus="$corpus"
  [ ${#short_corpus} -gt 30 ] && short_corpus="...${short_corpus: -27}"
  printf '%sв”Ӯ%s  %scorpus:%s  %-31s%sв”Ӯ%s\n' "$C_D" "$C_0" "$C_C" "$C_0" "$short_corpus" "$C_D" "$C_0"
  printf '%sв”Ӯ%s  %spages:%s   %-10s %sindexed:%s %-17s%sв”Ӯ%s\n' "$C_D" "$C_0" "$C_C" "$C_0" "$pages" "$C_C" "$C_0" "$indexed" "$C_D" "$C_0"
  printf '%sв”Ӯ%s  %smodel:%s   %-31s%sв”Ӯ%s\n' "$C_D" "$C_0" "$C_C" "$C_0" "$model" "$C_D" "$C_0"
  printf '%sв”Ӯ%s                                         %sв”Ӯ%s\n' "$C_D" "$C_0" "$C_D" "$C_0"
  printf '%sв”Ӯ%s  lorekit doctor   %sеҒҘеә·жЈҖжҹҘ%s              %sв”Ӯ%s\n' "$C_D" "$C_0" "$C_D" "$C_0" "$C_D" "$C_0"
  printf '%sв”Ӯ%s  lorekit fetch    %sжҠ“еҸ–зҪ‘йЎө%s              %sв”Ӯ%s\n' "$C_D" "$C_0" "$C_D" "$C_0" "$C_D" "$C_0"
  printf '%sв”Ӯ%s  lorekit search   %sжҗңзҙў%s                  %sв”Ӯ%s\n' "$C_D" "$C_0" "$C_D" "$C_0" "$C_D" "$C_0"
  printf '%sв”Ӯ%s  lorekit --help   %sжүҖжңүе‘Ҫд»Ө%s              %sв”Ӯ%s\n' "$C_D" "$C_0" "$C_D" "$C_0" "$C_D" "$C_0"
  printf '%sв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ%s\n' "$C_D" "$C_0"
}

cmd="${1:-}"; [ $# -gt 0 ] && shift || true
case "$cmd" in
  init|doctor|search|stats|lint|fetch|snapshot|restore|audit|vector|index) source "$LIB/$cmd.sh"; "cmd_$cmd" "$@" ;;
  install-skills) source "$LIB/install-skills.sh"; cmd_install_skills "$@" ;;
  version|--version) source "$LIB/version.sh"; cmd_version ;;
  "") _banner ;;
  -h|--help|help) cat <<EOF
lorekit $(lk_version) вҖ” Personal LLM Wiki Toolkit

Usage: lorekit <command> [args]

Commands:
  init [path] [--in-place] [--minimal]   Create corpus skeleton
  doctor                                  Health check current corpus
  lint [--quick] [--docs]                 Deep scan (orphans/broken/frontmatter)
  stats [--since Nd] [--type T]           Corpus statistics as JSON
  search <query> [--type T] [--dir D]     ripgrep wrapper, JSON lines
  fetch <url> [--out DIR] [--force-rich]  Fetch URL to local md+images, JSON out
  snapshot [--tag NAME]                   Create corpus snapshot (.tar.gz)
  restore --from <snap> [--dry-run]       Restore files from a snapshot
  audit [--list] [--open] [--resolved]    List/create feedback audit entries
  vector sync|query|status                Semantic vector search (ollama+sqlite-vec)
  index [--dir <subdir>]                  Generate/refresh _INDEX.md for corpus dirs
  install-skills --target claude-code     Install skills into a harness
  version                                 Print lorekit version
  --help                                  Show this help
EOF
    ;;
  *) lk_err "unknown command: $cmd (try: wiki --help)"; exit 2 ;;
esac
